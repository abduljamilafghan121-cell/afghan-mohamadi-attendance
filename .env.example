# Required — PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/attendix?schema=public"

# Required — Secret key for signing JWT tokens (min 32 characters recommended)
JWT_SECRET="your-secure-random-secret-here"

# Optional — Supabase (only if using Supabase for file uploads)
# NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
