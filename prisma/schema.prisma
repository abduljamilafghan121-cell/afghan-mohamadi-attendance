// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  employee
  manager
  admin
}

enum AttendanceEventType {
  check_in
  check_out
  admin_edit
}

enum AttendanceSessionStatus {
  open
  closed
  needs_approval
  corrected
}

enum DailyQrPurpose {
  check_in
  check_out
  both
}

enum LeaveRequestStatus {
  pending
  approved
  rejected
}

enum LeaveType {
  annual
  sick
  casual
  unpaid
}

enum CorrectionRequestStatus {
  pending
  approved
  rejected
}

enum CorrectionRequestType {
  check_in
  check_out
  both
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String?  @unique
  passwordHash String
  role         Role     @default(employee)
  isActive     Boolean  @default(true)

  employeeId String?
  phone      String?
  department String?
  jobTitle   String?
  address    String?
  photoUrl   String?

  managerId String?
  manager   User?   @relation("UserManager", fields: [managerId], references: [id])
  reports   User[]  @relation("UserManager")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendanceSessions AttendanceSession[]

  dailyQrTokensCreated DailyQrToken[] @relation("DailyQrCreatedBy")

  leaveRequests             LeaveRequest[]
  correctionRequests        CorrectionRequest[]
  correctionRequestsDecided CorrectionRequest[] @relation("CorrectionDecidedBy")
  attendanceAuditLogs       AttendanceAuditLog[]

  holidaysCreated   Holiday[]         @relation("HolidayCreatedBy")
  workdayOverrides  WorkdayOverride[] @relation("WorkdayOverrideUser")
  overridesCreated  WorkdayOverride[] @relation("WorkdayOverrideCreatedBy")
  leaveBalances     LeaveBalance[]

  shopsCreated   Shop[]    @relation("ShopCreatedBy")
  salesVisits    Visit[]   @relation("VisitUser")
  salesOrders    Order[]   @relation("OrderUser")
  salesPayments  Payment[] @relation("PaymentUser")

  weeklyPlanTemplates        WeeklyPlanTemplate[] @relation("WeeklyPlanTemplateUser")
  weeklyPlanTemplatesCreated WeeklyPlanTemplate[] @relation("WeeklyPlanTemplateCreatedBy")
  visitPlans                 VisitPlan[]          @relation("VisitPlanUser")
  visitPlansCreated          VisitPlan[]          @relation("VisitPlanCreatedBy")

  notifications  Notification[]
}

enum NotificationType {
  leave_submitted
  leave_decided
  correction_submitted
  correction_decided
  qr_generated
  late_check_in
  broadcast
  system
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(system)
  title     String
  body      String?
  link      String?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, isRead, createdAt(sort: Desc)])
}

enum CustomerType {
  new_customer
  existing
}

enum VisitPlanStatus {
  pending
  done
  missed
  cancelled
}

enum VisitPlanSource {
  template
  manual
}

model Region {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shops               Shop[]
  weeklyPlanTemplates WeeklyPlanTemplate[]

  @@index([name])
}

model WeeklyPlanTemplate {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("WeeklyPlanTemplateUser", fields: [userId], references: [id], onDelete: Cascade)
  weekday     Int
  regionId    String?
  region      Region?  @relation(fields: [regionId], references: [id])
  notes       String?
  isActive    Boolean  @default(true)
  createdById String?
  createdBy   User?    @relation("WeeklyPlanTemplateCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customers WeeklyPlanCustomer[]
  plans     VisitPlan[]

  @@unique([userId, weekday])
  @@index([weekday])
}

model WeeklyPlanCustomer {
  id         String             @id @default(cuid())
  templateId String
  template   WeeklyPlanTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  shopId     String
  shop       Shop               @relation(fields: [shopId], references: [id])
  createdAt  DateTime           @default(now())

  @@unique([templateId, shopId])
  @@index([shopId])
}

model VisitPlan {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation("VisitPlanUser", fields: [userId], references: [id], onDelete: Cascade)
  shopId       String
  shop         Shop            @relation(fields: [shopId], references: [id])
  plannedDate  DateTime
  notes        String?
  status       VisitPlanStatus @default(pending)
  source       VisitPlanSource @default(template)
  templateId   String?
  template     WeeklyPlanTemplate? @relation(fields: [templateId], references: [id])
  visitId      String?         @unique
  visit        Visit?          @relation(fields: [visitId], references: [id])
  createdById  String?
  createdBy    User?           @relation("VisitPlanCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([userId, plannedDate])
  @@index([status])
  @@index([shopId])
}

enum SalesPaymentType {
  cash
  credit
}

enum CollectionMethod {
  cash
  bank_transfer
  cheque
  other
}

model Shop {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  gpsLat    Float?
  gpsLng    Float?

  regionId  String?
  region    Region?  @relation(fields: [regionId], references: [id])

  createdById String?
  createdBy   User?    @relation("ShopCreatedBy", fields: [createdById], references: [id])

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visits             Visit[]
  orders             Order[]
  payments           Payment[]
  visitPlans         VisitPlan[]
  weeklyPlanCustomers WeeklyPlanCustomer[]

  @@index([name])
  @@index([regionId])
}

model Product {
  id        String   @id @default(cuid())
  name      String
  price     Float    @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems    OrderItem[]
  visitProducts VisitProduct[]

  @@index([name])
}

model Visit {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation("VisitUser", fields: [userId], references: [id])
  shopId       String
  shop         Shop         @relation(fields: [shopId], references: [id])
  customerType CustomerType @default(existing)
  notes        String?
  gpsLat       Float?
  gpsLng       Float?
  visitDate    DateTime     @default(now())
  createdAt    DateTime     @default(now())

  products VisitProduct[]

  plan VisitPlan?

  @@index([userId, visitDate])
  @@index([shopId])
}

model VisitProduct {
  id          String  @id @default(cuid())
  visitId     String
  visit       Visit   @relation(fields: [visitId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  productName  String
  offeredPrice Float?
  discussion   String?
  interest     String?

  @@unique([visitId, productId])
  @@index([visitId])
}

model Order {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation("OrderUser", fields: [userId], references: [id])
  shopId      String
  shop        Shop             @relation(fields: [shopId], references: [id])
  total       Float            @default(0)
  paymentType SalesPaymentType @default(cash)
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  items    OrderItem[]
  payments Payment[]

  @@index([userId, createdAt])
  @@index([shopId])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  productName String
  unitPrice   Float
  quantity    Int
  lineTotal   Float

  @@index([orderId])
}

model Payment {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation("PaymentUser", fields: [userId], references: [id])
  shopId       String?
  shop         Shop?            @relation(fields: [shopId], references: [id])
  customerName String
  amount       Float
  method       CollectionMethod @default(cash)
  notes        String?
  orderId      String?
  order        Order?           @relation(fields: [orderId], references: [id])
  createdAt    DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([shopId])
}

model LeaveRequest {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id])

  startDate DateTime
  endDate   DateTime
  reason    String?
  leaveType LeaveType          @default(annual)

  status      LeaveRequestStatus @default(pending)
  decidedAt   DateTime?
  decidedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, startDate, endDate])
  @@index([status, startDate, endDate])
}

model Organization {
  id      String @id @default(cuid())
  key     String @unique @default("primary")
  title   String
  logoUrl String?

  carryOverEnabled Boolean @default(true)
  carryOverMaxDays Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Office {
  id          String  @id @default(cuid())
  name        String
  gpsLat      Float
  gpsLng      Float
  gpsRadiusM  Int
  timezone    String  @default("UTC")
  isActive    Boolean @default(true)

  weeklyOffDays Int[]   @default([5])
  workStartTime String?
  workEndTime   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dailyQrTokens      DailyQrToken[]
  attendanceSessions AttendanceSession[]
}

model DailyQrToken {
  id        String        @id @default(cuid())
  officeId  String
  office    Office        @relation(fields: [officeId], references: [id])

  workDate  DateTime
  purpose   DailyQrPurpose @default(both)

  tokenHash String
  validFrom DateTime
  validTo   DateTime

  createdByAdminId String?
  createdByAdmin   User?   @relation("DailyQrCreatedBy", fields: [createdByAdminId], references: [id])

  createdAt DateTime @default(now())

  attendanceEvents AttendanceEvent[]

  @@index([officeId, workDate])
}

model AttendanceSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  officeId  String
  office    Office   @relation(fields: [officeId], references: [id])

  workDate  DateTime
  status    AttendanceSessionStatus @default(open)

  checkInAt  DateTime?
  checkOutAt DateTime?

  isLateArrival        Boolean @default(false)
  isEarlyDeparture     Boolean @default(false)
  isOvertime           Boolean @default(false)
  minutesLate          Int?
  minutesEarlyDeparture Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events             AttendanceEvent[]
  correctionRequests CorrectionRequest[]
  auditLogs          AttendanceAuditLog[]

  @@unique([userId, workDate])
  @@index([officeId, workDate])
}

model AttendanceEvent {
  id        String              @id @default(cuid())
  sessionId String
  session   AttendanceSession   @relation(fields: [sessionId], references: [id])
  type      AttendanceEventType

  serverTimeUtc DateTime
  gpsLat        Float
  gpsLng        Float
  gpsAccuracyM  Float?

  qrTokenId String
  qrToken   DailyQrToken @relation(fields: [qrTokenId], references: [id])

  validationPassed Boolean
  failureReason    String?

  createdAt DateTime @default(now())

  @@index([sessionId, type])
  @@index([qrTokenId])
}

model CorrectionRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  sessionId String?
  session   AttendanceSession? @relation(fields: [sessionId], references: [id])

  requestType      CorrectionRequestType
  workDate         DateTime
  intendedCheckIn  DateTime?
  intendedCheckOut DateTime?
  reason           String

  status      CorrectionRequestStatus @default(pending)
  decidedAt   DateTime?
  decidedById String?
  decidedBy   User?    @relation("CorrectionDecidedBy", fields: [decidedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, workDate])
  @@index([status])
}

model AttendanceAuditLog {
  id        String   @id @default(cuid())
  sessionId String
  session   AttendanceSession @relation(fields: [sessionId], references: [id])

  adminId   String
  admin     User     @relation(fields: [adminId], references: [id])

  field     String
  oldValue  String?
  newValue  String?
  note      String?

  createdAt DateTime @default(now())

  @@index([sessionId])
}

model Holiday {
  id          String   @id @default(cuid())
  date        DateTime @unique
  name        String
  createdById String?
  createdBy   User?    @relation("HolidayCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

model WorkdayOverride {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("WorkdayOverrideUser", fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  isOvertime  Boolean  @default(true)
  note        String?
  createdById String?
  createdBy   User?    @relation("WorkdayOverrideCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model LeaveBalance {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  year            Int
  leaveType       LeaveType
  entitlementDays Float     @default(0)
  usedDays        Float     @default(0)
  carriedOverDays Float     @default(0)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, year, leaveType])
  @@index([userId, year])
}
